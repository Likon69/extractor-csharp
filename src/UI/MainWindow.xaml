<Window x:Class="MaNGOS.Extractor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MaNGOS.Extractor.UI.ViewModels"
        xmlns:ctrl="clr-namespace:MaNGOS.Extractor.UI.Controls"
    Title="MaNGOS Extractor - WotLK 3.3.5a"
    Height="700"
    Width="1000"
    Background="{StaticResource WindowBackground}"
    BorderBrush="{StaticResource BorderBrush}"
    BorderThickness="1">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource PanelBackground}" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="▶ Démarrer" Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}"/>
                <Button Content="■ Stop" Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"/>
                <Separator Width="20"/>
                <Label Content="Phase:" VerticalAlignment="Center"/>
                <CheckBox Content="Map" IsChecked="{Binding Phases[0].IsEnabled}" VerticalAlignment="Center" Margin="4,0"/>
                <CheckBox Content="Vmap" IsChecked="{Binding Phases[1].IsEnabled}" VerticalAlignment="Center" Margin="4,0"/>
                <CheckBox Content="Road" IsChecked="{Binding Phases[2].IsEnabled}" VerticalAlignment="Center" Margin="4,0"/>
                <CheckBox Content="Mmap" IsChecked="{Binding Phases[3].IsEnabled}" VerticalAlignment="Center" Margin="4,0"/>
            </StackPanel>
        </Border>

        <!-- Main content: left panel + right grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Maps + Recast params (full height) -->
            <Border Grid.Column="0" Margin="0,0,8,0">
                <ScrollViewer>
                    <StackPanel Margin="8">
                        <!-- Maps section -->
                        <TextBlock Text="CARTES" FontWeight="Bold" Margin="0,0,0,4"/>
                        <!-- "Toutes" visible seulement si des maps sont chargées -->
                        <CheckBox Content="Toutes les cartes"
                                  IsChecked="{Binding SelectAllMaps}"
                                  Margin="0,0,0,4"
                                  Visibility="{Binding HasMaps, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <!-- Liste individuelle avec checkboxes -->
                        <Border MaxHeight="200" Margin="0,0,0,4"
                                Visibility="{Binding HasMaps, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedMaps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="4,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding MapId}" Width="38" Foreground="#999" FontSize="11"/>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <!-- Hint quand aucune map (chemin WoW non défini) -->
                        <TextBlock Text="→ Définir le chemin WoW pour charger les maps"
                                   Foreground="#888" FontStyle="Italic" FontSize="11" Margin="0,0,0,8"
                                   Visibility="{Binding HasMaps, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                        <Separator Margin="0,16"/>

                        <!-- Recast params section -->
                        <TextBlock Text="PARAMÈTRES RECAST" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="CellSize:"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CellSize, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="CellHeight:"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CellHeight, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Slope:"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WalkableSlopeAngle, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="Threads:" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center" FontWeight="Bold" MinWidth="22"
                                           Text="{Binding ThreadCount, StringFormat={}{0}}"/>
                                <Slider Minimum="1" Maximum="20"
                                        Value="{Binding ThreadCount, Mode=TwoWay}"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        Width="100" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Foreground="#888"
                                           Text="/ 20"/>
                            </StackPanel>

                            <Label Grid.Row="4" Grid.Column="0" Content="Locale:"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding Locales}" SelectedItem="{Binding SelectedLocale}"/>

                            <Label Grid.Row="5" Grid.Column="0" Content="Height:"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding WalkableHeight, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Grid.Row="6" Grid.Column="0" Content="Radius:"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding WalkableRadius, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Grid.Row="7" Grid.Column="0" Content="Climb:"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding WalkableClimb, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Grid.Row="8" Grid.Column="0" Content="One tile:"/>
                            <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding SingleTileEnabled}" VerticalAlignment="Center"/>

                            <Label Grid.Row="9" Grid.Column="0" Content="Tile X/Y:"/>
                            <Grid Grid.Row="9" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding SingleTileX, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Column="2" Text="{Binding SingleTileY, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Grid>

                        <Separator Margin="0,16"/>

                        <!-- Path configuration -->
                        <TextBlock Text="CHEMINS" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Label Content="WoW Client:"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding WowClientPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="..." Width="30" Command="{Binding BrowseWowCommand}"/>
                        </Grid>

                        <Label Content="Output:"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="..." Width="30" Command="{Binding BrowseOutputCommand}"/>
                        </Grid>

                        <Label Content="GO Spawns:"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding GoSpawnsPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="..." Width="30" Command="{Binding BrowseGoSpawnsCommand}"/>
                        </Grid>

                        <Label Content="OffMesh:"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding OffMeshPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="..." Width="30" Command="{Binding BrowseOffMeshCommand}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right panel: tile grid (top) + log (bottom, resizable via GridSplitter) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="180" MinHeight="60"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PanelBackground}">
                    <ctrl:MapGridControl ViewModel="{Binding TileGrid}"/>
                </Border>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}" Cursor="SizeNS"/>

                <!-- Log output (selectable + copyable, resizable) -->
                <Border Grid.Row="2" Background="#1E1E1E">
                    <TextBox x:Name="LogTextBox"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#D4D4D4"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="11"
                             Padding="8"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             TextWrapping="Wrap"
                             IsReadOnlyCaretVisible="False"/>
                </Border>
            </Grid>
        </Grid>

        <!-- Progress bar -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Value="{Binding Progress, Mode=OneWay}" Maximum="100" Height="20"/>
            <TextBlock Grid.Column="1" Margin="8,0,0,0">
                <Run Text="{Binding ProcessedTiles, Mode=OneWay}"/>
                <Run Text="/"/>
                <Run Text="{Binding TotalTiles, Mode=OneWay}"/>
                <Run Text=" tiles"/>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
